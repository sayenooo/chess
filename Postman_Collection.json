          "name": "Join Matchmaking Queue",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const data = pm.response.json();",
                  "    console.log('Status: ' + data.status);",
                  "    if (data.game_id) {",
                  "        pm.environment.set('online_game_id', data.game_id);",
                  "        pm.environment.set('online_room_name', data.game_id.toString());",
                  "        console.log('✅ Игра найдена! Game ID: ' + data.game_id);",
                  "    } else {",
                  "        console.log('⏳ Ожидание подбора противника...');",
                  "    }",
                  "} else {",
                  "    console.log('❌ Ошибка входа в очередь');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
