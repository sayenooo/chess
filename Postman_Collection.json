    {
      "name": "8. WEBSOCKET - MOVES (SOLO/BOT/ONLINE)",
      "item": [
        {
          "name": "🔗 SOLO - Move (e2 to e4)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "ws://localhost:8000/ws/game/{{solo_room_name}}/?type=solo",
              "protocol": "ws",
              "host": ["localhost"],
              "port": ["8000"],
              "path": ["ws", "game", "{{solo_room_name}}", ""],
              "query": [
                {
                  "key": "type",
                  "value": "solo"
                }
              ]
            },
            "description": "WebSocket запрос для хода в SOLO игре\n\nПосле подключения отправьте JSON:\n```json\n{\n  \"action\": \"move\",\n  \"from_square\": \"e2\",\n  \"to_square\": \"e4\"\n}\n```"
          }
        },
