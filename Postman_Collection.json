{
  "info": {
    "name": "Chess Game API",
    "description": "Полный набор запросов для тестирования шахматного приложения",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. AUTHENTICATION",
      "item": [
        {
          "name": "Register - Create Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.environment.set('username', pm.request.body.raw.username || 'testuser');",
                  "    console.log('✅ Регистрация успешна');",
                  "} else {",
                  "    console.log('❌ Ошибка регистрации');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser1\",\n  \"email\": \"test1@example.com\",\n  \"password\": \"TestPassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/register/",
              "host": ["{{base_url}}"],
              "path": ["api", "register", ""]
            }
          }
        },
        {
          "name": "Login - Get Tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('access_token', jsonData.access);",
                  "    pm.environment.set('refresh_token', jsonData.refresh);",
                  "    console.log('✅ Успешно получены токены');",
                  "    console.log('Access Token: ' + jsonData.access.substring(0, 20) + '...');",
                  "} else {",
                  "    console.log('❌ Ошибка входа');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser1\",\n  \"password\": \"TestPassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login/",
              "host": ["{{base_url}}"],
              "path": ["api", "login", ""]
            }
          }
        },
        {
          "name": "Refresh Access Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/token/refresh/",
              "host": ["{{base_url}}"],
              "path": ["api", "token", "refresh", ""]
            }
          }
        }
      ]
    },
    {
      "name": "2. PROFILE",
      "item": [
        {
          "name": "Get Current User Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const user = pm.response.json();",
                  "    pm.environment.set('user_id', user.id);",
                  "    console.log('✅ Профиль получен');",
                  "    console.log('Пользователь: ' + user.username);",
                  "} else {",
                  "    console.log('❌ Ошибка получения профиля');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/profile/",
              "host": ["{{base_url}}"],
              "path": ["api", "profile", ""]
            }
          }
        },
        {
          "name": "Update Username",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newusername123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/profile/username/",
              "host": ["{{base_url}}"],
              "path": ["api", "profile", "username", ""]
            }
          }
        },
        {
          "name": "Update Avatar",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "avatar",
                  "type": "file",
                  "src": "/path/to/avatar.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/profile/avatar/",
              "host": ["{{base_url}}"],
              "path": ["api", "profile", "avatar", ""]
            }
          }
        },
        {
          "name": "Delete Avatar",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/profile/avatar/",
              "host": ["{{base_url}}"],
              "path": ["api", "profile", "avatar", ""]
            }
          }
        }
      ]
    },
    {
      "name": "3. GAMES - SOLO (vs YOURSELF)",
      "item": [
        {
          "name": "Create SOLO Game",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const game = pm.response.json();",
                  "    pm.environment.set('solo_game_id', game.id);",
                  "    pm.environment.set('solo_room_name', game.id.toString());",
                  "    console.log('✅ SOLO игра создана');",
                  "    console.log('Game ID: ' + game.id);",
                  "} else {",
                  "    console.log('❌ Ошибка создания SOLO игры');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"game_type\": \"SOLO\",\n  \"time_control\": 15\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/games/",
              "host": ["{{base_url}}"],
              "path": ["api", "games", ""]
            }
          }
        },
